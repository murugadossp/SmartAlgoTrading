# Smart Algo Trading — Backend env example
# Copy to .env and fill in values. Do not commit .env.

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Dhan API
DHAN_ACCESS_TOKEN=
DHAN_CLIENT_ID=

# LLM
OPENAI_API_KEY=
LLM_MODEL=gpt-4o-mini

# News / web search (e.g. Serper)
SERPER_API_KEY=

# Optional: path to YAML config (watchlists, algo metadata)
CONFIG_PATH=
