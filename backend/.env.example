# Smart Algo Trading — Backend env example
# Copy to .env and fill in values. Do not commit .env.
#
# Config split: non-secret options (e.g. broker.provider) in backend/config/config.yaml;
# credentials and secrets below (in .env only).

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Broker credentials (always in env; never put in config.yaml)
DHAN_ACCESS_TOKEN=
DHAN_CLIENT_ID=

# LLM
OPENAI_API_KEY=
LLM_MODEL=gpt-4o-mini

# News / web search (e.g. Serper)
SERPER_API_KEY=

# Optional: override path to config dir or config file (default: backend/config/config.yaml)
CONFIG_PATH=
