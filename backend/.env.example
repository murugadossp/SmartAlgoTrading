# Smart Algo Trading — Backend env example
# Copy to .env and fill in values. Do not commit .env.
#
# Config: non-secret options in backend/config/config.yaml (broker, agents.default);
# credentials and secrets below (in .env only). See docs/config_agents.md for agent config.

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Broker credentials (always in env; never put in config.yaml)
DHAN_ACCESS_TOKEN=
DHAN_CLIENT_ID=

# LLM (AGNO; vendor-agnostic). Provider and model in config/config.yaml (agents.default); API keys here.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# News / web search (e.g. Serper)
SERPER_API_KEY=

# Optional: override path to config dir or config file (default: backend/config/config.yaml)
CONFIG_PATH=
